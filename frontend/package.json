{
  "name": "vocalize-ai-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "start": "vite --host 127.0.0.1",
    "preview": "vite preview",
